# flutter-biometric-auth-system — Environment Config
# Copy to .env — NEVER commit real values

# API
DEV_BASE_URL=https://dev-api.biometricauth.com/v1
QA_BASE_URL=https://qa-api.biometricauth.com/v1
UAT_BASE_URL=https://uat-api.biometricauth.com/v1
PROD_BASE_URL=https://api.biometricauth.com/v1

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PROJECT_NUMBER=your-project-number

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_TOKEN_EXPIRE_MINUTES=5

# Session Configuration
DEV_SESSION_TIMEOUT_SECONDS=300
QA_SESSION_TIMEOUT_SECONDS=300
UAT_SESSION_TIMEOUT_SECONDS=180
PROD_SESSION_TIMEOUT_SECONDS=120

# Auth Attempts
DEV_MAX_AUTH_ATTEMPTS=10
QA_MAX_AUTH_ATTEMPTS=5
PROD_MAX_AUTH_ATTEMPTS=3

# Encryption
DATA_ENCRYPTION_KEY=your-32-byte-aes-key-in-base64==
DATA_ENCRYPTION_IV=your-16-byte-iv-in-base64=
KEYCHAIN_ACCESS_GROUP=YOUR_TEAM_ID.com.avinash.biometric.auth

# OTP / MFA
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=5
SMS_PROVIDER_API_KEY=your-sms-provider-key
SMS_PROVIDER_SENDER_ID=your-sender-id

# Feature Flags
ENABLE_FACE_ID=true
ENABLE_FINGERPRINT=true
ENABLE_PIN_FALLBACK=true
ENABLE_MFA=true
ENABLE_JAILBREAK_DETECTION=true
ENABLE_SCREENSHOT_PREVENTION=true
ENABLE_DEVICE_BINDING=false

# Android Signing
ANDROID_KEYSTORE_BASE64=your-keystore-base64
ANDROID_KEY_ALIAS=your-key-alias
ANDROID_KEY_PASSWORD=your-key-password
ANDROID_STORE_PASSWORD=your-store-password

# iOS Signing
IOS_P12_BASE64=your-p12-base64
IOS_P12_PASSWORD=your-password
APPLE_TEAM_ID=YOUR_TEAM_ID

# Codecov
CODECOV_TOKEN=your-codecov-token
